import sys
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

if sys.stdout.encoding is None or sys.stdout.encoding.lower() != 'utf-8':
    try:
        sys.stdout.reconfigure(encoding='utf-8')
    except Exception:
        pass

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_absolute_error
from sklearn.metrics import r2_score

# Đọc dữ liệu
du_lieu = pd.read_excel("50_Startups.xlsx")

# Hiển thị dữ liệu
print(du_lieu.head())

# Kiểm tra dữ liệu thiếu
print(du_lieu.isnull().sum())

# Chuyển Bang sang dạng số
du_lieu = pd.get_dummies(du_lieu, columns=['Bang'], drop_first=True)

# Dữ liệu đầu vào và đầu ra
X_du_lieu = du_lieu.drop("Lợi nhuận", axis=1)

y_loi_nhuan = du_lieu["Lợi nhuận"]

# Chia dữ liệu
X_train, X_test, y_train, y_test = train_test_split(
    X_du_lieu,
    y_loi_nhuan,
    test_size=0.2,
    random_state=42
)

# Tạo mô hình
mo_hinh = LinearRegression()

# Huấn luyện
mo_hinh.fit(X_train, y_train)

# Dự đoán
y_du_doan = mo_hinh.predict(X_test)

# Đánh giá
mae = mean_absolute_error(y_test, y_du_doan)

r2 = r2_score(y_test, y_du_doan)

print("MAE:", mae)
print("Độ vừa ý R2:", r2)

# Vẽ biểu đồ
gia_tri_thuc = y_test
gia_tri_du_doan = y_du_doan
plt.scatter(gia_tri_thuc, gia_tri_du_doan)

plt.xlabel("Lợi nhuận thực tế")
plt.ylabel("Lợi nhuận dự đoán")
plt.title("Lợi nhuận thực tế so với dự đoán")
plt.show()
